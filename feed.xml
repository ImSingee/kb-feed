&lt;pre class=&quot;syntaxhighlighter-pre&quot; data-syntaxhighlighter-params=&quot;brush: java; gutter: false; theme: Confluence&quot; data-theme=&quot;Confluence&quot;&gt;// &#x65b0;&#x6dfb;&#x52a0;&#x7684;&#x526a;&#x679d;&#x903b;&#x8f91;&#xff0c;&#x56fa;&#x5b9a;&#x76f8;&#x540c;&#x7684;&#x5143;&#x7d20;&#x5728;&#x6392;&#x5217;&#x4e2d;&#x7684;&#x76f8;&#x5bf9;&#x4f4d;&#x7f6e;
