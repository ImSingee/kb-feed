&lt;pre class=&quot;syntaxhighlighter-pre&quot; data-syntaxhighlighter-params=&quot;brush: java; gutter: false; theme: Confluence&quot; data-theme=&quot;Confluence&quot;&gt;func permuteUnique(nums []int) (result [][]int) {
    used := make([]bool, 9)
    prev := make([]int, 0, 8)
    
    sort.Ints(nums)
    
    var backtrack func()
    backtrack = func() {
        if len(prev) == len(nums) {
            result = append(result, append([]int(nil), prev...))
            return
        }
        
        for i := 0; i &amp;lt; len(nums); i++ {
            num := nums[i]
            
            if i &amp;gt; 0 &amp;amp;&amp;amp; nums[i] == nums[i-1] &amp;amp;&amp;amp; !used[i-1] {
                continue
            }
            
            if used[i] {
                continue
            }
            
            prev = append(prev, num)
            used[i] = true
            
            backtrack()
            
            prev = prev[:len(prev)-1]
            used[i] = false
        }
    }
    backtrack()
    
    return
}&lt;/pre&gt;
